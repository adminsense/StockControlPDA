@page "/items"
@using Microsoft.EntityFrameworkCore
@using StockControl.Admin.Data
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Items (SKU)</PageTitle>

<FeedbackModal Success="@_success" Error="@_error" OnClosed="OnModalClosed" />

<section class="panel">
    <h2>Items (SKU)</h2>
    <SearchField ForId="item-search" Label="Search" Placeholder="sku, article no., product, name, or barcode" Value="@_search" ValueChanged="OnSearchChanged"
                 Hint="Search matches SKU, article number, product code, display name, and barcodes." />
</section>

<section class="panel">
    <h2>@(_editing.Id == 0 ? "New item" : "Edit item")</h2>
    <form @onsubmit="SaveAsync" @onsubmit:preventDefault="true">
        <div class="row">
            <div>
                <label for="item-sku">SKU *</label>
                <input id="item-sku" type="text" maxlength="40" @bind="_editing.Sku"
                       @onblur='() => ValidateMaxLength("SKU", _editing.Sku, 40)' required />
            </div>
            <div>
                <label for="item-article">Article number</label>
                <input id="item-article" type="text" maxlength="100" @bind="_editing.ArticleNumber"
                       @onblur='() => ValidateMaxLength("Article number", _editing.ArticleNumber, 100)' />
                <p class="hint" style="margin-top:6px;margin-bottom:0">Supplier / catalog article code (Artikelnummer). Distinct from internal SKU.</p>
            </div>
        </div>
        <div class="row">
            <div>
                <label for="item-unit">Quantity unit *</label>
                <input id="item-unit" type="text" maxlength="10" @bind="_editing.Unit"
                       @onblur='() => ValidateMaxLength("Quantity unit", _editing.Unit, 10)' required />
                <p class="hint" style="margin-top:6px;margin-bottom:0">Short code used with on-hand quantities (e.g. <span class="mono">ST</span>, <span class="mono">KG</span>, <span class="mono">M2</span>).</p>
            </div>
            <div>
                <label for="item-name">Display name *</label>
                <input id="item-name" type="text" maxlength="200" @bind="_editing.DisplayName"
                       @onblur='() => ValidateMaxLength("Display name", _editing.DisplayName, 200)' required />
            </div>
        </div>
        <div class="row">
            <div>
                <label for="item-product">Product *</label>
                <select id="item-product" @bind="_editing.ProductId" required>
                    <option value="0">-- Select --</option>
                    @foreach (var p in _productOptions)
                    {
                        <option value="@p.Id">@p.Code — @p.Name</option>
                    }
                </select>
            </div>
            <div>
                <label for="item-price">Price *</label>
                <input id="item-price" type="number" step="0.01" min="0" @bind="_editing.Price" />
            </div>
        </div>
        <div class="row">
            <div>
                <label for="item-packaging">Packaging *</label>
                <select id="item-packaging" value="@((int)_editing.PackagingType)" @onchange="OnPackagingSelectChanged">
                    @foreach (var pt in Enum.GetValues<PackagingType>())
                    {
                        <option value="@((int)pt)">@PackagingLabel(pt)</option>
                    }
                </select>
                <p class="hint" style="margin-top:6px;margin-bottom:0">How the item is counted when receiving or selling (each, box of N, pallet…). Not the same as quantity unit.</p>
            </div>
            <div>
                <label for="item-pkgqty">Package quantity *</label>
                <input id="item-pkgqty" type="number" step="0.001" min="0.001" @bind="_editing.PackageQuantity" />
            </div>
        </div>
        <div class="row">
            <div class="admin-form-span-2">
                <label for="item-barcodes">Barcodes (one per line)</label>
                <textarea id="item-barcodes" class="item-form-barcodes" rows="2" @bind="_barcodesText" placeholder="Ex.: 8712345678901"></textarea>
                <p class="hint" style="margin-bottom:0">One code per line; stored on the item. Each code must be unique across all items (scanner / wedge).</p>
            </div>
        </div>

        <div class="actions">
            <button class="btn success" type="submit" disabled="@_isSaving">@(_editing.Id == 0 ? "Save" : "Update")</button>
            <button class="btn danger" type="button" @onclick="CancelEdit">Cancel</button>
        </div>
    </form>
</section>

<section class="panel">
    <h2>List</h2>
    <div class="list-table-wrap">
        <table class="admin-items-table admin-grid-table">
            <colgroup>
                <col class="admin-it-col-sku" />
                <col class="admin-it-col-art" />
                <col class="admin-it-col-product" />
                <col class="admin-it-col-name" />
                <col class="admin-it-col-unit" />
                <col class="admin-it-col-pkg" />
                <col class="admin-it-col-pkgqty" />
                <col class="admin-it-col-price" />
                <col class="admin-it-col-status" />
                <col class="admin-it-col-actions" />
            </colgroup>
            <thead>
                <tr>
                    <SortableHeaderCell Label="SKU" SortKey="sku" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Art. no." SortKey="articleno" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Product" SortKey="product" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Name" SortKey="name" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Unit" SortKey="unit" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Pack." SortKey="packaging" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Pkg qty" SortKey="pkgqty" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" AlignEnd="true" />
                    <SortableHeaderCell Label="Price" SortKey="price" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" AlignEnd="true" />
                    <SortableHeaderCell Label="Status" SortKey="status" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <th class="admin-grid-th-actions" scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in PagedItems)
                {
                    <tr @key="i.Id"
                        class="@RowClass(i.Id, i.IsActive)"
                        @onclick="@(() => SelectItemRowAsync(i))">
                        <td class="mono">@i.Sku</td>
                        <td class="mono">@(string.IsNullOrWhiteSpace(i.ArticleNumber) ? "—" : i.ArticleNumber)</td>
                        <td class="mono">@i.ProductCode</td>
                        <td>@i.DisplayName</td>
                        <td>@i.Unit</td>
                        <td>@PackagingLabel(i.PackagingType)</td>
                        <td class="col-num admin-it-td-num">@i.PackageQuantity.ToString("0.###")</td>
                        <td class="col-num admin-it-td-num">@i.Price.ToString("0.00")</td>
                        <td><span class="tag @(i.IsActive ? "ok" : "off")">@(i.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="admin-grid-td-actions" @onclick:stopPropagation="true">
                            <div class="mini-actions mini-actions-row">
                                <EditIconButton Title="Edit item" OnClick="@(() => StartEdit(i.Id))" Disabled="@(!i.IsActive)" />
                                <ActiveToggle IsActive="i.IsActive" OnToggle="@(() => ToggleActiveAsync(i.Id))" />
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="actions" style="justify-content:space-between">
        <div class="hint" style="margin:0">Showing <strong>@_itemsShowFrom</strong>-<strong>@_itemsShowTo</strong> of <strong>@_itemsTotalRows</strong></div>
        <div class="mini-actions">
            <button class="edit" type="button" @onclick="PrevItemsPage" disabled="@(_itemsPageIndex == 0)">Prev</button>
            <button class="edit" type="button" @onclick="NextItemsPage" disabled="@(_itemsPageIndex >= _itemsMaxPageIndex)">Next</button>
        </div>
    </div>
</section>

@code {
    private string _search = "";
    private string _status = "";
    private bool _isSaving;
    private Item _editing = new()
    {
        PackagingType = PackagingType.Unit,
        PackageQuantity = 1m,
        Price = 0m,
        Barcodes = ""
    };
    private int? _selectedRowId;
    private string _barcodesText = "";
    private List<ItemRow> _items = [];
    private List<Product> _productOptions = [];
    private string? _success;
    private string? _error;

    private const int PageSize = 10;
    private int _itemsPageIndex;
    private string? _sortKey;
    private bool _sortDesc;

    private string RowClass(int id, bool isActive)
    {
        var cls = isActive ? "admin-grid-row-clickable" : "admin-grid-row-inactive";
        if (_selectedRowId == id)
            cls += " admin-grid-row-clickable--selected";
        return cls;
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        ResetFormToNew();
    }

    private Task OnSearchChanged(string v)
    {
        _search = v;
        ResetItemsPaging();
        return Task.CompletedTask;
    }

    private IEnumerable<ItemRow> FilteredItems
        => _items.Where(i =>
            (string.IsNullOrWhiteSpace(_search) ||
             i.Sku.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             (!string.IsNullOrWhiteSpace(i.ArticleNumber) && i.ArticleNumber.Contains(_search, StringComparison.OrdinalIgnoreCase)) ||
             i.ProductCode.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             i.DisplayName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             (i.BarcodesCsv ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase))
            && (_status switch
            {
                "active" => i.IsActive,
                "inactive" => !i.IsActive,
                _ => true
            }));

    private int _itemsTotalRows => OrderedFilteredItems.Count();
    private int _itemsMaxPageIndex => Math.Max(0, (_itemsTotalRows - 1) / PageSize);
    private int _itemsShowFrom => _itemsTotalRows == 0 ? 0 : (_itemsPageIndex * PageSize) + 1;
    private int _itemsShowTo => Math.Min(_itemsTotalRows, (_itemsPageIndex * PageSize) + PageSize);
    private IEnumerable<ItemRow> PagedItems => OrderedFilteredItems.Skip(_itemsPageIndex * PageSize).Take(PageSize);

    private IEnumerable<ItemRow> OrderedFilteredItems
    {
        get
        {
            var q = FilteredItems;
            if (string.IsNullOrEmpty(_sortKey))
                return q.OrderByDescending(i => i.Id);
            return _sortKey switch
            {
                "sku" => _sortDesc ? q.OrderByDescending(i => i.Sku) : q.OrderBy(i => i.Sku),
                "articleno" => _sortDesc ? q.OrderByDescending(i => i.ArticleNumber) : q.OrderBy(i => i.ArticleNumber),
                "product" => _sortDesc ? q.OrderByDescending(i => i.ProductCode) : q.OrderBy(i => i.ProductCode),
                "name" => _sortDesc ? q.OrderByDescending(i => i.DisplayName) : q.OrderBy(i => i.DisplayName),
                "unit" => _sortDesc ? q.OrderByDescending(i => i.Unit) : q.OrderBy(i => i.Unit),
                "packaging" => _sortDesc ? q.OrderByDescending(i => (int)i.PackagingType) : q.OrderBy(i => (int)i.PackagingType),
                "pkgqty" => _sortDesc ? q.OrderByDescending(i => i.PackageQuantity) : q.OrderBy(i => i.PackageQuantity),
                "price" => _sortDesc ? q.OrderByDescending(i => i.Price) : q.OrderBy(i => i.Price),
                "status" => _sortDesc ? q.OrderByDescending(i => i.IsActive) : q.OrderBy(i => i.IsActive),
                _ => q.OrderByDescending(i => i.Id)
            };
        }
    }

    private void RequestSort(string key)
    {
        if (string.Equals(_sortKey, key, StringComparison.Ordinal))
            _sortDesc = !_sortDesc;
        else
        {
            _sortKey = key;
            _sortDesc = true;
        }
        _itemsPageIndex = 0;
    }

    private void ResetItemsPaging()
    {
        _itemsPageIndex = 0;
    }

    private async Task ReloadAsync()
    {
        ResetItemsPaging();
        await using var db = await DbFactory.CreateDbContextAsync();
        _productOptions = await db.Products.AsNoTracking().OrderBy(p => p.Code).ToListAsync();

        var list = await db.Items
            .AsNoTracking()
            .Include(i => i.Product)
            .OrderBy(i => i.Sku)
            .ToListAsync();

        _items = list.Select(i => new ItemRow(
            i.Id,
            i.Sku,
            i.ArticleNumber,
            i.Product?.Code ?? "",
            i.DisplayName,
            i.Unit,
            i.PackagingType,
            i.PackageQuantity,
            i.Price,
            i.IsActive,
            ItemBarcodeInput.Preview(i.Barcodes)
        )).ToList();
    }

    private void PrevItemsPage()
    {
        if (_itemsPageIndex > 0)
            _itemsPageIndex--;
    }

    private void NextItemsPage()
    {
        if (_itemsPageIndex < _itemsMaxPageIndex)
            _itemsPageIndex++;
    }

    private void ResetFormToNew()
    {
        _error = null;
        _selectedRowId = null;
        _editing = new Item
        {
            PackagingType = PackagingType.Unit,
            PackageQuantity = 1m,
            Price = 0m,
            Barcodes = ""
        };
        _barcodesText = "";
    }

    private async Task SelectItemRowAsync(ItemRow row)
    {
        if (!row.IsActive)
            return;
        await StartEdit(row.Id);
    }

    private async Task StartEdit(int itemId)
    {
        _success = null;
        _error = null;
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Items.FirstOrDefaultAsync(x => x.Id == itemId);
        if (entity is null)
        {
            _selectedRowId = null;
            return;
        }

        if (!entity.IsActive)
        {
            _selectedRowId = null;
            return;
        }

        _selectedRowId = itemId;
        _editing = new Item
        {
            Id = entity.Id,
            ProductId = entity.ProductId,
            Sku = entity.Sku,
            ArticleNumber = entity.ArticleNumber,
            DisplayName = entity.DisplayName,
            Unit = entity.Unit,
            PackagingType = entity.PackagingType,
            PackageQuantity = entity.PackageQuantity,
            Price = entity.Price,
            IsActive = entity.IsActive,
            Barcodes = entity.Barcodes,
            CreatedAt = entity.CreatedAt,
            UpdatedAt = entity.UpdatedAt
        };
        _barcodesText = ItemBarcodeInput.FormatForEditor(entity.Barcodes);
    }

    private void CancelEdit()
    {
        _success = null;
        _error = null;
        ResetFormToNew();
    }

    private async Task SaveAsync()
    {
        _success = null;
        _error = null;
        _editing.Sku = (_editing.Sku ?? "").Trim().ToUpperInvariant();
        _editing.ArticleNumber = (_editing.ArticleNumber ?? "").Trim();
        _editing.DisplayName = (_editing.DisplayName ?? "").Trim();
        _editing.Unit = (_editing.Unit ?? "").Trim().ToUpperInvariant();

        var barcodeCodes = ItemBarcodeInput.ParseLines(_barcodesText);
        var validationError = ItemsSaveValidation.ValidateSave(
            _editing.Sku,
            _editing.ArticleNumber,
            _editing.DisplayName,
            _editing.Unit,
            _editing.ProductId,
            _editing.PackageQuantity,
            _editing.PackagingType,
            _editing.Price,
            barcodeCodes);
        if (validationError is not null)
        {
            _error = validationError;
            return;
        }

        _isSaving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var conflict = await ItemBarcodeConflictFinder.FindConflictAsync(db, _editing.Id, barcodeCodes);
            if (conflict is not null)
            {
                _error = conflict;
                return;
            }

            var barcodesNormalized = ItemBarcodeInput.Join(barcodeCodes);

            if (_editing.Id == 0)
            {
                _editing.CreatedAt = DateTimeOffset.UtcNow;
                _editing.Barcodes = barcodesNormalized;
                db.Items.Add(_editing);
            }
            else
            {
                var entity = await db.Items.FirstOrDefaultAsync(x => x.Id == _editing.Id);
                if (entity is null)
                    return;

                entity.ProductId = _editing.ProductId;
                entity.Sku = _editing.Sku;
                entity.ArticleNumber = _editing.ArticleNumber;
                entity.DisplayName = _editing.DisplayName;
                entity.Unit = _editing.Unit;
                entity.PackagingType = _editing.PackagingType;
                entity.PackageQuantity = _editing.PackageQuantity;
                entity.Price = _editing.Price;
                entity.IsActive = _editing.IsActive;
                entity.Barcodes = barcodesNormalized;
                entity.UpdatedAt = DateTimeOffset.UtcNow;
            }

            await db.SaveChangesAsync();
            _success = "Saved successfully.";
            await ReloadAsync();
            ResetFormToNew();
        }
        catch (Exception ex)
        {
            _error = DbErrorTranslator.TryGetUserFriendlyMessage(ex, out var msg) ? msg : "Unexpected error. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private Task OnModalClosed()
    {
        _success = null;
        _error = null;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ValidateMaxLength(string fieldName, string? value, int maxLength)
    {
        var err = FieldBlurValidation.MaxLengthExceeded(fieldName, value, maxLength);
        if (err is not null)
            _error = err;
    }

    private async Task ToggleActiveAsync(int itemId)
    {
        _success = null;
        _error = null;
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Items.FirstOrDefaultAsync(x => x.Id == itemId);
        if (entity is null)
            return;

        entity.IsActive = !entity.IsActive;
        entity.UpdatedAt = DateTimeOffset.UtcNow;
        try
        {
            await db.SaveChangesAsync();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = DbErrorTranslator.TryGetUserFriendlyMessage(ex, out var msg) ? msg : "Unexpected error. Please try again.";
        }
    }

    private void OnPackagingSelectChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v) && Enum.IsDefined(typeof(PackagingType), v))
        {
            _editing.PackagingType = (PackagingType)v;
            if (_editing.PackagingType == PackagingType.Unit)
                _editing.PackageQuantity = 1m;
        }
    }

    private static string PackagingLabel(PackagingType t) => t switch
    {
        PackagingType.Unit => "Unit",
        PackagingType.Box => "Box",
        PackagingType.Case => "Case",
        PackagingType.Pallet => "Pallet",
        PackagingType.Bag => "Bag",
        PackagingType.Kit => "Kit",
        _ => t.ToString()
    };

    private record ItemRow(
        int Id,
        string Sku,
        string ArticleNumber,
        string ProductCode,
        string DisplayName,
        string Unit,
        PackagingType PackagingType,
        decimal PackageQuantity,
        decimal Price,
        bool IsActive,
        string? BarcodesCsv);
}
