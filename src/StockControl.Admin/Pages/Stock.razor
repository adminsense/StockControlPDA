@page "/"
@page "/stock"
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using StockControl.Admin.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>Stock</PageTitle>

<FeedbackModal Success="@_success" Error="@_error" OnClosed="OnFeedbackClosed" />

@if (_syncBusy)
{
    <div class="sc-modal-backdrop" role="alertdialog" aria-busy="true" aria-live="polite" aria-label="Synchronizing">
        <div class="sc-modal sc-modal--busy" role="dialog" aria-modal="true">
            <div class="sc-modal-body sc-modal-body--busy">
                <div class="sc-spinner" aria-hidden="true"></div>
                <p class="sc-busy-text">Synchronizing with the item catalog…</p>
            </div>
        </div>
    </div>
}

<section class="panel">
    <h2>Stock</h2>
    <div class="row">
        <div>
            <label for="stock-warehouse">Warehouse</label>
            <select id="stock-warehouse" @bind="_warehouseId" @bind:after="OnWarehouseChanged">
                <option value="0">All</option>
                @foreach (var w in _warehouses)
                {
                    <option value="@w.Id">@w.Code - @w.Name</option>
                }
            </select>
        </div>
        <div>
            <label for="stock-location">Location</label>
            <select id="stock-location" @bind="_locationId">
                <option value="0">All</option>
                @foreach (var l in _locationsForFilter)
                {
                    <option value="@l.Id">@l.Code</option>
                }
            </select>
        </div>
    </div>
    <div class="row">
        <div>
            <label for="stock-search">Search</label>
            <input id="stock-search" type="text" placeholder="sku, article no., product, or name" @bind="_search" />
        </div>
        <div>
            <label for="stock-only-belowmin">Filter</label>
            <select id="stock-only-belowmin" @bind="_filter">
                <option value="">All</option>
                <option value="below">Below min</option>
                <option value="above">Above max</option>
            </select>
        </div>
    </div>
    <div class="actions">
        <button id="stock-sync-btn" class="btn ghost" type="button" @onclick="OnSyncClickedAsync">Sync</button>
    </div>
    <p class="hint">This screen shows current on-hand quantities per <strong>warehouse + location</strong> and compares to Min/Max when available.</p>
</section>

<section class="panel">
    <h2>List</h2>
    <div class="stock-table-scroll">
        <table class="stock-table admin-stock-table admin-grid-table">
            <colgroup>
                <col class="admin-st-col-wh" />
                <col class="admin-st-col-loc" />
                <col class="admin-st-col-product" />
                <col class="admin-st-col-sku" />
                <col class="admin-st-col-art" />
                <col class="admin-st-col-name" />
                <col class="admin-st-col-qty" />
                <col class="admin-st-col-min" />
                <col class="admin-st-col-max" />
                <col class="admin-st-col-status" />
            </colgroup>
            <thead>
                <tr>
                    <SortableHeaderCell Label="Warehouse" SortKey="warehouse" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Location" SortKey="location" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Product" SortKey="product" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="SKU" SortKey="sku" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Art. no." SortKey="articleno" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Name" SortKey="name" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="On hand" SortKey="onhand" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" AlignEnd="true" />
                    <SortableHeaderCell Label="Min" SortKey="min" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" AlignEnd="true" />
                    <SortableHeaderCell Label="Max" SortKey="max" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" AlignEnd="true" />
                    <SortableHeaderCell Label="Status" SortKey="status" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" AlignEnd="true" />
                </tr>
            </thead>
            <tbody>
                @foreach (var r in PagedRows)
                {
                    <tr @key="r.Id">
                        <td class="mono">@r.WarehouseCode</td>
                        <td class="mono">@r.LocationCode</td>
                        <td class="mono">@r.ProductCode</td>
                        <td class="mono">@r.Sku</td>
                        <td class="mono">@(string.IsNullOrWhiteSpace(r.ArticleNumber) ? "—" : r.ArticleNumber)</td>
                        <td>@r.DisplayName</td>
                        <td class="stock-td-num" style="text-align:right">@r.QuantityOnHand.ToString("0.###")</td>
                        <td class="stock-td-num" style="text-align:right">@(r.Min?.ToString() ?? "—")</td>
                        <td class="stock-td-num" style="text-align:right">@(r.Max?.ToString() ?? "—")</td>
                        <td class="stock-td-num" style="text-align:right">
                            @if (r.Min is not null && r.QuantityOnHand < r.Min)
                            {
                                <span class="tag off">Below</span>
                            }
                            else if (r.Max is not null && r.QuantityOnHand > r.Max)
                            {
                                <span class="tag off">Above</span>
                            }
                            else
                            {
                                <span class="tag ok">OK</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="actions" style="justify-content:space-between">
        <div class="hint" style="margin:0">
            Showing <strong>@_showFrom</strong>-<strong>@_showTo</strong> of <strong>@_totalRows</strong>
        </div>
        <div class="mini-actions">
            <button class="edit" type="button" @onclick="PrevPage" disabled="@(_pageIndex == 0)">Prev</button>
            <button class="edit" type="button" @onclick="NextPage" disabled="@(_pageIndex >= _maxPageIndex)">Next</button>
        </div>
    </div>
</section>

@code {
    private string? _success;
    private string? _error;
    private bool _syncBusy;
    private DateTimeOffset _itemsActivityBaseline;

    private int _warehouseId;
    private int _locationId;
    private string _search = "";
    private string _filter = "";

    private List<Warehouse> _warehouses = [];
    private List<Location> _allLocations = [];
    private List<Location> _locationsForFilter = [];
    private List<Row> _rows = [];
    private const int PageSize = 10;
    private int _pageIndex;
    private string? _sortKey;
    private bool _sortDesc;

    protected override async Task OnInitializedAsync()
    {
        await LoadStockGridAsync();
        await using var db = await DbFactory.CreateDbContextAsync();
        _itemsActivityBaseline = await GetLatestItemActivityUtcAsync(db);
    }

    private Task OnFeedbackClosed()
    {
        _success = null;
        _error = null;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private static async Task<DateTimeOffset> GetLatestItemActivityUtcAsync(AppDbContext db)
    {
        if (!await db.Items.AsNoTracking().AnyAsync())
            return DateTimeOffset.MinValue;

        return await db.Items.AsNoTracking().MaxAsync(i => i.UpdatedAt ?? i.CreatedAt);
    }

    private async Task OnSyncClickedAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("stockControl.blurActive");
        }
        catch
        {
            // non-fatal if script not loaded
        }

        _success = null;
        _error = null;

        await using var db = await DbFactory.CreateDbContextAsync();
        var marker = await GetLatestItemActivityUtcAsync(db);

        if (marker <= _itemsActivityBaseline)
        {
            _success = "Everything is synchronized.";
            StateHasChanged();
            return;
        }

        _syncBusy = true;
        StateHasChanged();

        try
        {
            await Task.Delay(350);
            await LoadStockGridAsync();
            await using var db2 = await DbFactory.CreateDbContextAsync();
            _itemsActivityBaseline = await GetLatestItemActivityUtcAsync(db2);
            _success = "Synchronization completed.";
        }
        finally
        {
            _syncBusy = false;
            StateHasChanged();
        }
    }

    private IEnumerable<Row> FilteredRows
        => _rows.Where(r => StockGridFilter.Matches(
            new StockFilterRow(
                r.WarehouseId,
                r.LocationId,
                r.ProductCode,
                r.Sku,
                r.ArticleNumber,
                r.DisplayName,
                r.QuantityOnHand,
                r.Min,
                r.Max),
            _warehouseId,
            _locationId,
            _search,
            _filter));

    private int _totalRows => OrderedFilteredRows.Count();
    private int _maxPageIndex => StockGridPaging.MaxPageIndex(_totalRows, PageSize);
    private int _showFrom => StockGridPaging.ShowFrom(_totalRows, _pageIndex, PageSize);
    private int _showTo => StockGridPaging.ShowTo(_totalRows, _pageIndex, PageSize);

    private IEnumerable<Row> PagedRows
        => OrderedFilteredRows
            .Skip(_pageIndex * PageSize)
            .Take(PageSize);

    private IEnumerable<Row> OrderedFilteredRows
    {
        get
        {
            var q = FilteredRows;
            if (string.IsNullOrEmpty(_sortKey))
                return q.OrderByDescending(r => r.Id);
            return _sortKey switch
            {
                "warehouse" => _sortDesc ? q.OrderByDescending(r => r.WarehouseCode) : q.OrderBy(r => r.WarehouseCode),
                "location" => _sortDesc ? q.OrderByDescending(r => r.LocationCode) : q.OrderBy(r => r.LocationCode),
                "product" => _sortDesc ? q.OrderByDescending(r => r.ProductCode) : q.OrderBy(r => r.ProductCode),
                "sku" => _sortDesc ? q.OrderByDescending(r => r.Sku) : q.OrderBy(r => r.Sku),
                "articleno" => _sortDesc ? q.OrderByDescending(r => r.ArticleNumber) : q.OrderBy(r => r.ArticleNumber),
                "name" => _sortDesc ? q.OrderByDescending(r => r.DisplayName) : q.OrderBy(r => r.DisplayName),
                "onhand" => _sortDesc ? q.OrderByDescending(r => r.QuantityOnHand) : q.OrderBy(r => r.QuantityOnHand),
                "min" => _sortDesc
                    ? q.OrderByDescending(r => r.Min ?? int.MinValue)
                    : q.OrderBy(r => r.Min.HasValue ? 0 : 1).ThenBy(r => r.Min ?? int.MaxValue),
                "max" => _sortDesc
                    ? q.OrderByDescending(r => r.Max ?? int.MinValue)
                    : q.OrderBy(r => r.Max.HasValue ? 0 : 1).ThenBy(r => r.Max ?? int.MaxValue),
                "status" => _sortDesc ? q.OrderByDescending(StatusRank).ThenBy(r => r.Sku) : q.OrderBy(StatusRank).ThenBy(r => r.Sku),
                _ => q.OrderByDescending(r => r.Id)
            };
        }
    }

    private static int StatusRank(Row r)
    {
        if (r.Min is not null && r.QuantityOnHand < r.Min) return 0;
        if (r.Max is not null && r.QuantityOnHand > r.Max) return 2;
        return 1;
    }

    private void RequestSort(string key)
    {
        if (string.Equals(_sortKey, key, StringComparison.Ordinal))
            _sortDesc = !_sortDesc;
        else
        {
            _sortKey = key;
            _sortDesc = true;
        }
        _pageIndex = 0;
    }

    private async Task LoadStockGridAsync()
    {
        _pageIndex = 0;
        await using var db = await DbFactory.CreateDbContextAsync();
        _warehouses = await db.Warehouses.OrderBy(x => x.Code).ToListAsync();
        _allLocations = await db.Locations.OrderBy(x => x.Code).ToListAsync();
        SyncLocationsForFilter();

        var minmaxByKey = await db.MinMaxSettings
            .AsNoTracking()
            .ToDictionaryAsync(x => (x.WarehouseId, x.ItemId, x.LocationId), x => (x.Min, x.Max));

        var list = await db.StockBalances
            .AsNoTracking()
            .Include(x => x.Warehouse)
            .Include(x => x.Location)
            .Include(x => x.Item)
                .ThenInclude(i => i!.Product)
            .Select(b => new
            {
                b.Id,
                b.WarehouseId,
                WarehouseCode = b.Warehouse!.Code,
                b.LocationId,
                LocationCode = b.Location!.Code,
                b.ItemId,
                ProductCode = b.Item!.Product != null ? b.Item.Product.Code : "",
                Sku = b.Item.Sku,
                ArticleNumber = b.Item.ArticleNumber,
                DisplayName = b.Item.DisplayName,
                b.QuantityOnHand
            })
            .OrderBy(x => x.WarehouseCode)
            .ThenBy(x => x.LocationCode)
            .ThenBy(x => x.Sku)
            .ToListAsync();

        _rows = list.Select(x =>
        {
            (int Min, int Max)? mm = null;
            if (minmaxByKey.TryGetValue((x.WarehouseId, x.ItemId, x.LocationId), out var locMm))
                mm = locMm;

            return new Row(
                x.Id,
                x.WarehouseId,
                x.WarehouseCode,
                x.LocationId,
                x.LocationCode,
                x.ProductCode,
                x.Sku,
                x.ArticleNumber,
                x.DisplayName,
                x.QuantityOnHand,
                mm?.Min,
                mm?.Max);
        }).ToList();
    }

    private void OnWarehouseChanged()
    {
        _locationId = 0;
        _pageIndex = 0;
        SyncLocationsForFilter();
    }

    private void SyncLocationsForFilter()
    {
        _locationsForFilter = _warehouseId == 0
            ? _allLocations.OrderBy(x => x.Code).ToList()
            : _allLocations.Where(x => x.WarehouseId == _warehouseId).OrderBy(x => x.Code).ToList();
    }

    private void PrevPage()
    {
        if (_pageIndex > 0)
            _pageIndex--;
    }

    private void NextPage()
    {
        if (_pageIndex < _maxPageIndex)
            _pageIndex++;
    }

    private record Row(
        int Id,
        int WarehouseId,
        string WarehouseCode,
        int LocationId,
        string LocationCode,
        string ProductCode,
        string Sku,
        string ArticleNumber,
        string DisplayName,
        decimal QuantityOnHand,
        int? Min,
        int? Max);
}
