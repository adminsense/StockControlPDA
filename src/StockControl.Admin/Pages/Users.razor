@page "/users"
@using Microsoft.EntityFrameworkCore
@using StockControl.Admin.Auth
@using StockControl.Admin.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject PasswordHasherService PasswordHasher

<PageTitle>Users</PageTitle>

<FeedbackModal Success="@_success" Error="@_error" OnClosed="() => { _success = null; _error = null; }" />

<section class="panel">
    <h2>Users</h2>
    <SearchField ForId="user-search" Label="Search" Placeholder="name or username" Value="@_search" ValueChanged="OnSearchChanged"
                 Hint="Search matches username and name." />
</section>

<section class="panel">
    <h2>@(_editing.Id == 0 ? "New user" : "Edit user")</h2>
    <form @onsubmit="SaveAsync" @onsubmit:preventDefault="true">
        <div class="row">
            <div>
                <label for="user-username">Username *</label>
                <input id="user-username" type="text" maxlength="50" @bind="_editing.Username"
                       @onblur='() => ValidateMaxLength("Username", _editing.Username, 50)' required />
            </div>
            <div>
                <label for="user-name">Name *</label>
                <input id="user-name" type="text" maxlength="50" @bind="_editing.Name"
                       @onblur='() => ValidateMaxLength("Name", _editing.Name, 50)' required />
            </div>
            <div>
                <label for="user-role">Role *</label>
                <select id="user-role" @bind="_roleValue">
                    <option value="1">Admin (1)</option>
                    <option value="2">Admin PDA (2)</option>
                </select>
            </div>
            <div>
                <label for="user-password">@(_editing.Id == 0 ? "Password *" : "Password")</label>
                <input id="user-password" type="password" autocomplete="new-password" @bind="_password"
                       placeholder="@(_editing.Id == 0 ? "" : "Leave blank to keep current")" />
            </div>
        </div>

        <div class="actions">
            <button class="btn success" type="submit" disabled="@_isSaving">@(_editing.Id == 0 ? "Save" : "Update")</button>
            <button class="btn danger" type="button" @onclick="CancelEdit">Cancel</button>
        </div>
    </form>
</section>

<section class="panel">
    <h2>List</h2>
    <div class="list-table-wrap">
        <table class="admin-users-table admin-grid-table">
            <colgroup>
                <col class="admin-us-col-user" />
                <col class="admin-us-col-name" />
                <col class="admin-us-col-role" />
                <col class="admin-us-col-created" />
                <col class="admin-us-col-status" />
                <col class="admin-us-col-actions" />
            </colgroup>
            <thead>
                <tr>
                    <SortableHeaderCell Label="User" SortKey="username" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Name" SortKey="name" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Role" SortKey="role" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Created" SortKey="created" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Status" SortKey="status" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <th class="admin-grid-th-actions" scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in PagedUsers)
                {
                    <tr @key="u.Id"
                        class="@RowClass(u.Id, u.IsActive)"
                        @onclick="@(() => OnUserRowClick(u))">
                        <td class="mono admin-us-td-user">@u.Username</td>
                        <td class="admin-us-td-name">@u.Name</td>
                        <td class="admin-us-td-role">@UsersSaveValidation.RoleLabel(u.Role)</td>
                        <td class="admin-us-td-created mono">@FormatCreated(u.CreatedAt)</td>
                        <td class="admin-us-td-status"><span class="tag @(u.IsActive ? "ok" : "off")">@(u.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="admin-grid-td-actions" @onclick:stopPropagation="true">
                            <div class="mini-actions mini-actions-row">
                                <EditIconButton Title="Edit user" OnClick="@(() => StartEdit(u))" Disabled="@(!u.IsActive)" />
                                <ActiveToggle IsActive="u.IsActive" OnToggle="@(() => ToggleActiveAsync(u))" />
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="actions" style="justify-content:space-between">
        <div class="hint" style="margin:0">Showing <strong>@_showFrom</strong>-<strong>@_showTo</strong> of <strong>@_totalRows</strong></div>
        <div class="mini-actions">
            <button class="edit" type="button" @onclick="PrevPage" disabled="@(_pageIndex == 0)">Prev</button>
            <button class="edit" type="button" @onclick="NextPage" disabled="@(_pageIndex >= _maxPageIndex)">Next</button>
        </div>
    </div>
    <p class="hint">Roles: <strong>1</strong> = Admin (web), <strong>2</strong> = Admin PDA. Deactivate instead of deleting.</p>
</section>

@code {
    private string _search = "";
    private string _status = "";
    private bool _isSaving;
    private AppUser _editing = new();
    private string _password = "";
    private int _roleValue = (int)UserRole.AdminPda;
    private int? _selectedRowId;
    private string? _success;
    private string? _error;

    private List<AppUser> _users = [];
    private const int PageSize = 10;
    private int _pageIndex;
    private string? _sortKey;
    private bool _sortDesc;

    private string RowClass(int id, bool isActive)
    {
        var cls = isActive ? "admin-grid-row-clickable" : "admin-grid-row-inactive";
        if (_selectedRowId == id)
            cls += " admin-grid-row-clickable--selected";
        return cls;
    }

    private static string FormatCreated(DateTimeOffset createdAt)
        => createdAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private void OnUserRowClick(AppUser u)
    {
        if (!u.IsActive)
            return;
        StartEdit(u);
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        ResetFormToNew();
    }

    private Task OnSearchChanged(string v)
    {
        _search = v;
        ResetPaging();
        return Task.CompletedTask;
    }

    private IEnumerable<AppUser> FilteredUsers
        => _users.Where(u =>
            (string.IsNullOrWhiteSpace(_search) ||
             u.Username.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             u.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
            && (_status switch
            {
                "active" => u.IsActive,
                "inactive" => !u.IsActive,
                _ => true
            }));

    private int _totalRows => OrderedFilteredUsers.Count();
    private int _maxPageIndex => Math.Max(0, (_totalRows - 1) / PageSize);
    private int _showFrom => _totalRows == 0 ? 0 : (_pageIndex * PageSize) + 1;
    private int _showTo => Math.Min(_totalRows, (_pageIndex * PageSize) + PageSize);
    private IEnumerable<AppUser> PagedUsers => OrderedFilteredUsers.Skip(_pageIndex * PageSize).Take(PageSize);

    private IEnumerable<AppUser> OrderedFilteredUsers
    {
        get
        {
            var q = FilteredUsers;
            if (string.IsNullOrEmpty(_sortKey))
                return q.OrderByDescending(x => x.Id);
            return _sortKey switch
            {
                "username" => _sortDesc ? q.OrderByDescending(x => x.Username) : q.OrderBy(x => x.Username),
                "name" => _sortDesc ? q.OrderByDescending(x => x.Name) : q.OrderBy(x => x.Name),
                "role" => _sortDesc ? q.OrderByDescending(x => x.Role) : q.OrderBy(x => x.Role),
                "created" => _sortDesc ? q.OrderByDescending(x => x.CreatedAt) : q.OrderBy(x => x.CreatedAt),
                "status" => _sortDesc ? q.OrderByDescending(x => x.IsActive) : q.OrderBy(x => x.IsActive),
                _ => q.OrderByDescending(x => x.Id)
            };
        }
    }

    private void RequestSort(string key)
    {
        if (string.Equals(_sortKey, key, StringComparison.Ordinal))
            _sortDesc = !_sortDesc;
        else
        {
            _sortKey = key;
            _sortDesc = true;
        }
        _pageIndex = 0;
    }

    private void ResetPaging()
    {
        _pageIndex = 0;
    }

    private async Task ReloadAsync()
    {
        ResetPaging();
        await using var db = await DbFactory.CreateDbContextAsync();
        _users = await db.Users.OrderBy(x => x.Username).ToListAsync();
    }

    private void PrevPage()
    {
        if (_pageIndex > 0)
            _pageIndex--;
    }

    private void NextPage()
    {
        if (_pageIndex < _maxPageIndex)
            _pageIndex++;
    }

    private void ResetFormToNew()
    {
        _error = null;
        _selectedRowId = null;
        _editing = new AppUser();
        _password = "";
        _roleValue = (int)UserRole.AdminPda;
    }

    private void StartEdit(AppUser u)
    {
        if (!u.IsActive)
            return;

        _success = null;
        _error = null;
        _selectedRowId = u.Id;
        _editing = new AppUser
        {
            Id = u.Id,
            Username = u.Username,
            Name = u.Name,
            Role = u.Role,
            IsActive = u.IsActive,
            CreatedAt = u.CreatedAt,
            UpdatedAt = u.UpdatedAt
        };
        _password = "";
        _roleValue = (int)u.Role;
    }

    private void CancelEdit()
    {
        _success = null;
        _error = null;
        ResetFormToNew();
    }

    private async Task SaveAsync()
    {
        _success = null;
        _error = null;
        _editing.Username = (_editing.Username ?? "").Trim();
        _editing.Name = (_editing.Name ?? "").Trim();

        _editing.Role = Enum.IsDefined(typeof(UserRole), _roleValue)
            ? (UserRole)_roleValue
            : UserRole.AdminPda;

        var validationError = UsersSaveValidation.ValidateSave(
            _editing.Username, _editing.Name, _editing.Role, _editing.Id == 0, _password);
        if (validationError is not null)
        {
            _error = validationError;
            return;
        }

        _isSaving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            if (_editing.Id == 0)
            {
                _editing.CreatedAt = DateTimeOffset.UtcNow;
                _editing.PasswordHash = PasswordHasher.Hash(_editing, _password.Trim());
                db.Users.Add(_editing);
            }
            else
            {
                var entity = await db.Users.FirstOrDefaultAsync(x => x.Id == _editing.Id);
                if (entity is null)
                {
                    _error = "User not found.";
                    return;
                }

                entity.Username = _editing.Username;
                entity.Name = _editing.Name;
                entity.Role = _editing.Role;
                entity.UpdatedAt = DateTimeOffset.UtcNow;
                if (!string.IsNullOrWhiteSpace(_password))
                    entity.PasswordHash = PasswordHasher.Hash(entity, _password.Trim());
            }

            await db.SaveChangesAsync();
            _success = "Saved successfully.";
            await ReloadAsync();
            ResetFormToNew();
        }
        catch (Exception ex)
        {
            _error = DbErrorTranslator.TryGetUserFriendlyMessage(ex, out var msg) ? msg : "Unexpected error. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ValidateMaxLength(string fieldName, string? value, int maxLength)
    {
        var err = FieldBlurValidation.MaxLengthExceeded(fieldName, value, maxLength);
        if (err is not null)
            _error = err;
    }

    private async Task ToggleActiveAsync(AppUser u)
    {
        _success = null;
        _error = null;
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Users.FirstOrDefaultAsync(x => x.Id == u.Id);
        if (entity is null)
            return;

        entity.IsActive = !entity.IsActive;
        entity.UpdatedAt = DateTimeOffset.UtcNow;
        try
        {
            await db.SaveChangesAsync();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = DbErrorTranslator.TryGetUserFriendlyMessage(ex, out var msg) ? msg : "Unexpected error. Please try again.";
        }
    }
}
