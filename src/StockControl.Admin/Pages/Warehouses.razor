@page "/warehouses"
@using Microsoft.EntityFrameworkCore
@using StockControl.Admin.Data
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Warehouses</PageTitle>

<FeedbackModal Success="@_success" Error="@_error" OnClosed="() => { _success = null; _error = null; }" />

<section class="panel">
    <h2>Warehouses</h2>
    <SearchField ForId="wh-search" Label="Search" Placeholder="code or name" Value="@_search" ValueChanged="OnSearchChanged"
                 Hint="Search matches warehouse code and name." />
</section>

<section class="panel">
    <h2>@(_editing.Id == 0 ? "New warehouse" : "Edit warehouse")</h2>
    <form @onsubmit="SaveAsync" @onsubmit:preventDefault="true">
        <div class="row">
            <div>
                <label for="wh-code">Code *</label>
                <input id="wh-code" type="text" maxlength="20" @bind="_editing.Code"
                       @onblur='() => ValidateMaxLength("Code", _editing.Code, 20)' required />
            </div>
            <div>
                <label for="wh-name">Name *</label>
                <input id="wh-name" type="text" maxlength="50" @bind="_editing.Name"
                       @onblur='() => ValidateMaxLength("Name", _editing.Name, 50)' required />
            </div>
        </div>

        <div class="actions">
            <button class="btn success" type="submit" disabled="@_isSaving">@(_editing.Id == 0 ? "Save" : "Update")</button>
            <button class="btn danger" type="button" @onclick="CancelEdit">Cancel</button>
        </div>
    </form>
</section>

<section class="panel">
    <h2>List</h2>
    <div class="list-table-wrap">
        <table class="admin-master-table admin-grid-table">
            <colgroup>
                <col class="admin-ms-col-code" />
                <col class="admin-ms-col-name" />
                <col class="admin-ms-col-status" />
                <col class="admin-ms-col-actions" />
            </colgroup>
            <thead>
                <tr>
                    <SortableHeaderCell Label="Code" SortKey="code" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Name" SortKey="name" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <SortableHeaderCell Label="Status" SortKey="status" ActiveKey="@_sortKey" Descending="@_sortDesc" SortRequested="RequestSort" />
                    <th class="admin-grid-th-actions" scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var w in PagedWarehouses)
                {
                    <tr @key="w.Id"
                        class="@RowClass(w.Id, w.IsActive)"
                        @onclick="@(() => OnWarehouseRowClick(w))">
                        <td class="mono">@w.Code</td>
                        <td>@w.Name</td>
                        <td><span class="tag @(w.IsActive ? "ok" : "off")">@(w.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="admin-grid-td-actions" @onclick:stopPropagation="true">
                            <div class="mini-actions mini-actions-row">
                                <EditIconButton Title="Edit warehouse" OnClick="@(() => StartEdit(w))" Disabled="@(!w.IsActive)" />
                                <ActiveToggle IsActive="w.IsActive" OnToggle="@(() => ToggleActiveAsync(w))" />
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="actions" style="justify-content:space-between">
        <div class="hint" style="margin:0">Showing <strong>@_showFrom</strong>-<strong>@_showTo</strong> of <strong>@_totalRows</strong></div>
        <div class="mini-actions">
            <button class="edit" type="button" @onclick="PrevPage" disabled="@(_pageIndex == 0)">Prev</button>
            <button class="edit" type="button" @onclick="NextPage" disabled="@(_pageIndex >= _maxPageIndex)">Next</button>
        </div>
    </div>
</section>

@code {
    private string _search = "";
    private string _status = "";
    private bool _isSaving;
    private Warehouse _editing = new();
    private int? _selectedRowId;
    private List<Warehouse> _warehouses = [];
    private string? _success;
    private string? _error;
    private const int PageSize = 10;
    private int _pageIndex;
    private string? _sortKey;
    private bool _sortDesc;

    private string RowClass(int id, bool isActive)
    {
        var cls = isActive ? "admin-grid-row-clickable" : "admin-grid-row-inactive";
        if (_selectedRowId == id)
            cls += " admin-grid-row-clickable--selected";
        return cls;
    }

    private void OnWarehouseRowClick(Warehouse w)
    {
        if (!w.IsActive)
            return;
        StartEdit(w);
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        ResetFormToNew();
    }

    private Task OnSearchChanged(string v)
    {
        _search = v;
        ResetPaging();
        return Task.CompletedTask;
    }

    private IEnumerable<Warehouse> FilteredWarehouses
        => _warehouses.Where(w =>
            (string.IsNullOrWhiteSpace(_search) ||
             w.Code.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             w.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
            && (_status switch
            {
                "active" => w.IsActive,
                "inactive" => !w.IsActive,
                _ => true
            }));

    private int _totalRows => OrderedFilteredWarehouses.Count();
    private int _maxPageIndex => Math.Max(0, (_totalRows - 1) / PageSize);
    private int _showFrom => _totalRows == 0 ? 0 : (_pageIndex * PageSize) + 1;
    private int _showTo => Math.Min(_totalRows, (_pageIndex * PageSize) + PageSize);
    private IEnumerable<Warehouse> PagedWarehouses => OrderedFilteredWarehouses.Skip(_pageIndex * PageSize).Take(PageSize);

    private IEnumerable<Warehouse> OrderedFilteredWarehouses
    {
        get
        {
            var q = FilteredWarehouses;
            if (string.IsNullOrEmpty(_sortKey))
                return q.OrderByDescending(x => x.Id);
            return _sortKey switch
            {
                "code" => _sortDesc ? q.OrderByDescending(x => x.Code) : q.OrderBy(x => x.Code),
                "name" => _sortDesc ? q.OrderByDescending(x => x.Name) : q.OrderBy(x => x.Name),
                "status" => _sortDesc ? q.OrderByDescending(x => x.IsActive) : q.OrderBy(x => x.IsActive),
                _ => q.OrderByDescending(x => x.Id)
            };
        }
    }

    private void RequestSort(string key)
    {
        if (string.Equals(_sortKey, key, StringComparison.Ordinal))
            _sortDesc = !_sortDesc;
        else
        {
            _sortKey = key;
            _sortDesc = true;
        }
        _pageIndex = 0;
    }

    private void ResetPaging()
    {
        _pageIndex = 0;
    }

    private async Task ReloadAsync()
    {
        ResetPaging();
        await using var db = await DbFactory.CreateDbContextAsync();
        _warehouses = await db.Warehouses.OrderBy(x => x.Code).ToListAsync();
    }

    private void PrevPage()
    {
        if (_pageIndex > 0)
            _pageIndex--;
    }

    private void NextPage()
    {
        if (_pageIndex < _maxPageIndex)
            _pageIndex++;
    }

    private void ResetFormToNew()
    {
        _error = null;
        _selectedRowId = null;
        _editing = new Warehouse();
    }

    private void StartEdit(Warehouse w)
    {
        if (!w.IsActive)
            return;

        _success = null;
        _error = null;
        _selectedRowId = w.Id;
        _editing = new Warehouse
        {
            Id = w.Id,
            Code = w.Code,
            Name = w.Name,
            IsActive = w.IsActive,
            CreatedAt = w.CreatedAt,
            UpdatedAt = w.UpdatedAt
        };
    }

    private void CancelEdit()
    {
        _success = null;
        _error = null;
        ResetFormToNew();
    }

    private async Task SaveAsync()
    {
        _success = null;
        _error = null;
        _editing.Code = (_editing.Code ?? "").Trim().ToUpperInvariant();
        _editing.Name = (_editing.Name ?? "").Trim();

        var validationError = WarehousesSaveValidation.ValidateSave(_editing.Code, _editing.Name);
        if (validationError is not null)
        {
            _error = validationError;
            return;
        }

        _isSaving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            if (_editing.Id == 0)
            {
                _editing.CreatedAt = DateTimeOffset.UtcNow;
                db.Warehouses.Add(_editing);
            }
            else
            {
                _editing.UpdatedAt = DateTimeOffset.UtcNow;
                db.Warehouses.Update(_editing);
            }

            await db.SaveChangesAsync();
            _success = "Saved successfully.";
            await ReloadAsync();
            ResetFormToNew();
        }
        catch (Exception ex)
        {
            _error = DbErrorTranslator.TryGetUserFriendlyMessage(ex, out var msg) ? msg : "Unexpected error. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ValidateMaxLength(string fieldName, string? value, int maxLength)
    {
        var err = FieldBlurValidation.MaxLengthExceeded(fieldName, value, maxLength);
        if (err is not null)
            _error = err;
    }

    private async Task ToggleActiveAsync(Warehouse w)
    {
        _success = null;
        _error = null;
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Warehouses.FirstOrDefaultAsync(x => x.Id == w.Id);
        if (entity is null)
            return;

        entity.IsActive = !entity.IsActive;
        entity.UpdatedAt = DateTimeOffset.UtcNow;
        try
        {
            await db.SaveChangesAsync();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = DbErrorTranslator.TryGetUserFriendlyMessage(ex, out var msg) ? msg : "Unexpected error. Please try again.";
        }
    }
}
