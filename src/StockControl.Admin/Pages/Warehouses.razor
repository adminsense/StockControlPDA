@page "/warehouses"
@using Microsoft.EntityFrameworkCore
@using StockControl.Admin.Data
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Warehouses</PageTitle>

<FeedbackModal Success="@_success" Error="@_error" OnClosed="() => { _success = null; _error = null; }" />

<section class="panel">
    <h2>Warehouses</h2>
    <label for="wh-search">Search</label>
    <input id="wh-search" type="text" placeholder="code or name" @bind="_search" @bind:after="ResetPaging" />
    <div class="actions">
        <button class="btn primary" type="button" @onclick="StartCreate">+ New</button>
        <button class="btn ghost" type="button" @onclick="ReloadAsync">Sync</button>
    </div>
</section>

@if (_editing is not null)
{
    <section class="panel">
        <h2>@(_editing.Id == 0 ? "New warehouse" : "Edit warehouse")</h2>
        <form @onsubmit="SaveAsync" @onsubmit:preventDefault="true">
            <div class="row">
                <div>
                    <label for="wh-code">Code *</label>
                    <input id="wh-code" type="text" maxlength="20" @bind="_editing.Code"
                           @onblur='() => ValidateMaxLength("Code", _editing.Code, 20)' required />
                </div>
                <div>
                    <label for="wh-name">Name *</label>
                    <input id="wh-name" type="text" maxlength="50" @bind="_editing.Name"
                           @onblur='() => ValidateMaxLength("Name", _editing.Name, 50)' required />
                </div>
            </div>
            <div class="row">
                <div>
                    <label for="wh-status">Status</label>
                    <select id="wh-status" @bind="_editing.IsActive">
                        <option value="@true">Active</option>
                        <option value="@false">Inactive</option>
                    </select>
                </div>
            </div>

            <div class="actions">
                <button class="btn success" type="submit" disabled="@_isSaving">Save</button>
                <button class="btn danger" type="button" @onclick="CancelEdit">Cancel</button>
            </div>
        </form>
    </section>
}

<section class="panel">
    <h2>List</h2>
    <div style="overflow-x:auto">
        <table>
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Status</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var w in PagedWarehouses)
                {
                    <tr @key="w.Id">
                        <td class="mono">@w.Code</td>
                        <td>@w.Name</td>
                        <td><span class="tag @(w.IsActive ? "ok" : "off")">@(w.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <div class="mini-actions">
                                <button class="edit" type="button" @onclick="@(() => StartEdit(w))">Edit</button>
                                <button class="del" type="button" @onclick="@(() => ToggleActiveAsync(w))">@(w.IsActive ? "Deactivate" : "Activate")</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="actions" style="justify-content:space-between">
        <div class="hint" style="margin:0">Showing <strong>@_showFrom</strong>-<strong>@_showTo</strong> of <strong>@_totalRows</strong></div>
        <div class="mini-actions">
            <button class="edit" type="button" @onclick="PrevPage" disabled="@(_pageIndex == 0)">Prev</button>
            <button class="edit" type="button" @onclick="NextPage" disabled="@(_pageIndex >= _maxPageIndex)">Next</button>
        </div>
    </div>
</section>

@code {
    private string _search = "";
    private string _status = "";
    private bool _isSaving;
    private Warehouse? _editing;
    private List<Warehouse> _warehouses = [];
    private string? _success;
    private string? _error;
    private const int PageSize = 10;
    private int _pageIndex;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private IEnumerable<Warehouse> FilteredWarehouses
        => _warehouses.Where(w =>
            (string.IsNullOrWhiteSpace(_search) ||
             w.Code.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             w.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
            && (_status switch
            {
                "active" => w.IsActive,
                "inactive" => !w.IsActive,
                _ => true
            }));

    private int _totalRows => FilteredWarehouses.Count();
    private int _maxPageIndex => Math.Max(0, (_totalRows - 1) / PageSize);
    private int _showFrom => _totalRows == 0 ? 0 : (_pageIndex * PageSize) + 1;
    private int _showTo => Math.Min(_totalRows, (_pageIndex * PageSize) + PageSize);
    private IEnumerable<Warehouse> PagedWarehouses => FilteredWarehouses.Skip(_pageIndex * PageSize).Take(PageSize);

    private void ResetPaging()
    {
        _pageIndex = 0;
    }

    private async Task ReloadAsync()
    {
        ResetPaging();
        await using var db = await DbFactory.CreateDbContextAsync();
        _warehouses = await db.Warehouses.OrderBy(x => x.Code).ToListAsync();
    }

    private void PrevPage()
    {
        if (_pageIndex > 0)
            _pageIndex--;
    }

    private void NextPage()
    {
        if (_pageIndex < _maxPageIndex)
            _pageIndex++;
    }

    private void StartCreate()
    {
        _success = null;
        _error = null;
        _editing = new Warehouse();
    }

    private void StartEdit(Warehouse w)
    {
        _success = null;
        _error = null;
        _editing = new Warehouse
        {
            Id = w.Id,
            Code = w.Code,
            Name = w.Name,
            IsActive = w.IsActive,
            CreatedAt = w.CreatedAt,
            UpdatedAt = w.UpdatedAt
        };
    }

    private void CancelEdit() => _editing = null;

    private async Task SaveAsync()
    {
        if (_editing is null)
            return;

        _success = null;
        _error = null;
        _editing.Code = (_editing.Code ?? "").Trim().ToUpperInvariant();
        _editing.Name = (_editing.Name ?? "").Trim();

        if (string.IsNullOrWhiteSpace(_editing.Code))
        {
            _error = "Code is required.";
            return;
        }
        if (_editing.Code.Length > 20)
        {
            _error = "Code must be 20 characters or fewer.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_editing.Name))
        {
            _error = "Name is required.";
            return;
        }
        if (_editing.Name.Length > 50)
        {
            _error = "Name must be 50 characters or fewer.";
            return;
        }

        _isSaving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            if (_editing.Id == 0)
            {
                _editing.CreatedAt = DateTimeOffset.UtcNow;
                db.Warehouses.Add(_editing);
            }
            else
            {
                _editing.UpdatedAt = DateTimeOffset.UtcNow;
                db.Warehouses.Update(_editing);
            }

            await db.SaveChangesAsync();
            _editing = null;
            _success = "Saved successfully.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = DbErrorTranslator.TryGetUserFriendlyMessage(ex, out var msg) ? msg : "Unexpected error. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ValidateMaxLength(string fieldName, string? value, int maxLength)
    {
        var v = value ?? "";
        if (v.Length > maxLength)
            _error = $"{fieldName} must be {maxLength} characters or fewer.";
    }

    private async Task ToggleActiveAsync(Warehouse w)
    {
        _success = null;
        _error = null;
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.Warehouses.FirstOrDefaultAsync(x => x.Id == w.Id);
        if (entity is null)
            return;

        entity.IsActive = !entity.IsActive;
        entity.UpdatedAt = DateTimeOffset.UtcNow;
        try
        {
            await db.SaveChangesAsync();
            _success = "Saved successfully.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = DbErrorTranslator.TryGetUserFriendlyMessage(ex, out var msg) ? msg : "Unexpected error. Please try again.";
        }
    }
}

