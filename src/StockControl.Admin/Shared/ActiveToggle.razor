@* Visual 100% inline: não depende de admin-theme nem de ordem de CSS — trilho, ON/OFF e bolinha sempre corretos. *@
<button type="button"
        class="admin-active-toggle-btn"
        style="display:inline-flex;align-items:center;justify-content:center;border:none;padding:0;margin:0;background:transparent;cursor:pointer;line-height:0;box-shadow:none;font-family:system-ui,-apple-system,'Segoe UI',sans-serif;"
        @onclick="HandleClickAsync"
        title="@(IsActive ? "ON — click to turn OFF" : "OFF — click to turn ON")"
        aria-pressed="@IsActive">
    <span style="@RailStyle">
        <span style="@OnLabelStyle">ON</span>
        <span style="@KnobStyle"></span>
        <span style="@OffLabelStyle">OFF</span>
    </span>
</button>

@code {
    [Parameter] public bool IsActive { get; set; }

    [Parameter] public EventCallback OnToggle { get; set; }

    private string RailStyle => IsActive
        ? "position:relative;display:block;width:58px;height:28px;border-radius:14px;overflow:hidden;box-sizing:border-box;background:linear-gradient(180deg,#4ade80 0%,#22c55e 44%,#16a34a 100%);box-shadow:inset 0 2px 4px rgba(0,0,0,.22),inset 0 -1px 0 rgba(255,255,255,.12);"
        : "position:relative;display:block;width:58px;height:28px;border-radius:14px;overflow:hidden;box-sizing:border-box;background:linear-gradient(180deg,#d1d5db 0%,#c4cbd4 40%,#aeb6c2 100%);box-shadow:inset 0 2px 4px rgba(0,0,0,.18),inset 0 -1px 0 rgba(255,255,255,.1);";

    private string OnLabelStyle => IsActive
        ? "position:absolute;left:9px;top:50%;transform:translateY(-50%);font-size:9px;font-weight:900;letter-spacing:.08em;user-select:none;pointer-events:none;z-index:1;color:rgba(20,83,45,.92);text-shadow:0 1px 0 rgba(255,255,255,.28),0 -1px 0 rgba(0,0,0,.12);opacity:1;"
        : "position:absolute;left:9px;top:50%;transform:translateY(-50%);font-size:9px;font-weight:900;letter-spacing:.08em;user-select:none;pointer-events:none;z-index:1;color:rgba(55,65,81,.55);opacity:.22;text-shadow:none;";

    private string OffLabelStyle => IsActive
        ? "position:absolute;right:8px;top:50%;transform:translateY(-50%);font-size:9px;font-weight:900;letter-spacing:.08em;user-select:none;pointer-events:none;z-index:1;color:rgba(55,65,81,.55);opacity:.2;text-shadow:none;"
        : "position:absolute;right:8px;top:50%;transform:translateY(-50%);font-size:9px;font-weight:900;letter-spacing:.08em;user-select:none;pointer-events:none;z-index:1;color:rgba(55,65,81,.96);text-shadow:0 1px 0 rgba(255,255,255,.42),0 -1px 0 rgba(0,0,0,.08);opacity:1;";

    private string KnobStyle => IsActive
        ? "position:absolute;top:3px;left:33px;width:22px;height:22px;border-radius:50%;z-index:2;box-sizing:border-box;background:linear-gradient(180deg,#ffffff 0%,#f3f4f6 100%);box-shadow:0 1px 3px rgba(0,0,0,.28),0 0 0 1px rgba(0,0,0,.06);transition:left .2s ease;"
        : "position:absolute;top:3px;left:3px;width:22px;height:22px;border-radius:50%;z-index:2;box-sizing:border-box;background:linear-gradient(180deg,#ffffff 0%,#f3f4f6 100%);box-shadow:0 1px 3px rgba(0,0,0,.28),0 0 0 1px rgba(0,0,0,.06);transition:left .2s ease;";

    private async Task HandleClickAsync()
    {
        await OnToggle.InvokeAsync();
    }
}
