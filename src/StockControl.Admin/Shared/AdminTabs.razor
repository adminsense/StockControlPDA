@using StockControl.Admin.Auth

<div class="tabs-admin-shell">
    <nav class="tabs tabs-admin-grid" role="tablist" aria-label="Admin sections">
        <NavLink href="/users" class="tabs-admin-tab-link admin-nav-r2-c1" role="tab" aria-selected="@IsActive("/users")" Match="NavLinkMatch.All">Users</NavLink>
        <NavLink href="/warehouses" class="tabs-admin-tab-link admin-nav-r2-c2" role="tab" aria-selected="@IsActive("/warehouses")">Warehouses</NavLink>
        <NavLink href="/locations" class="tabs-admin-tab-link admin-nav-r2-c3" role="tab" aria-selected="@IsActive("/locations")">Locations</NavLink>
        <NavLink href="/suppliers" class="tabs-admin-tab-link admin-nav-r2-c4" role="tab" aria-selected="@IsActive("/suppliers")">Suppliers</NavLink>
        <NavLink href="/products" class="tabs-admin-tab-link admin-nav-r3-c1" role="tab" aria-selected="@IsActive("/products")">Products</NavLink>
        <NavLink href="/items" class="tabs-admin-tab-link admin-nav-r3-c2" role="tab" aria-selected="@IsActive("/items")">Items (SKU)</NavLink>
        <NavLink href="/minmax" class="tabs-admin-tab-link admin-nav-r3-c3" role="tab" aria-selected="@IsActive("/minmax")">Min / Max</NavLink>
        <AuthorizeView Roles="@AuthConstants.AdminRole">
            <Authorized>
                <NavLink href="/audit" class="tabs-admin-tab-link admin-nav-r3-c4" role="tab" aria-selected="@IsActive("/audit")">Audit Logs</NavLink>
            </Authorized>
            <NotAuthorized>
                <span class="tabs-admin-placeholder admin-nav-r3-c4" aria-hidden="true"></span>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private static string NormalizePath(string rel)
    {
        if (string.IsNullOrWhiteSpace(rel))
            return "/";
        rel = rel.Trim();
        if (!rel.StartsWith('/'))
            rel = "/" + rel;
        var i = rel.IndexOf('?', StringComparison.Ordinal);
        if (i >= 0)
            rel = rel[..i];
        return rel.TrimEnd('/') is "" ? "/" : rel.TrimEnd('/');
    }

    private bool IsActive(string href)
    {
        var rel = NormalizePath(Nav.ToBaseRelativePath(Nav.Uri));
        return string.Equals(rel, href.TrimEnd('/'), StringComparison.OrdinalIgnoreCase);
    }
}
