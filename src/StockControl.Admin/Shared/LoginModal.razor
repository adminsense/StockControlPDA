@using StockControl.Admin.Auth
@inject IJSRuntime Js
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<div class="login-page" role="presentation">
    <div class="login-card" role="dialog" aria-modal="true" aria-label="Sign in">
        <h1 class="login-heading">Stock Control — Admin</h1>

        <form class="login-form" @onsubmit="SubmitAsync" @onsubmit:preventDefault="true">
            <label class="login-label" for="login-user">Username</label>
            <input id="login-user"
                   class="login-field"
                   type="text"
                   autocomplete="username"
                   placeholder="Username"
                   @bind="_username"
                   disabled="@_busy" />

            <label class="login-label" for="login-pass">Password</label>
            <input id="login-pass"
                   class="login-field"
                   type="password"
                   autocomplete="current-password"
                   placeholder="Password"
                   @bind="_password"
                   disabled="@_busy" />

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <p class="login-error">@_error</p>
            }

            <button class="login-submit" type="submit" disabled="@_busy">Sign in</button>
        </form>
    </div>
</div>

@code {
    private string _username = "";
    private string _password = "";
    private string? _error;
    private bool _busy;

    private async Task SubmitAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            var result = await Js.InvokeAsync<LoginJsResult>("loginAdmin", _username.Trim(), _password);
            if (result is { Ok: true, Token: not null and not "" })
            {
                if (AuthState is ServerAuthenticationStateProvider serverAuth)
                    serverAuth.SetAuthenticatedFromToken(result.Token);
                Nav.NavigateTo("/stock");
                return;
            }

            _error = result?.Error ?? "Sign in failed.";
        }
        catch (JSException ex)
        {
            _error = string.IsNullOrWhiteSpace(ex.Message) ? "Sign in failed. Please try again." : ex.Message;
        }
        catch (Exception)
        {
            _error = "Sign in failed. Please try again.";
        }
        finally
        {
            _busy = false;
        }
    }
}
