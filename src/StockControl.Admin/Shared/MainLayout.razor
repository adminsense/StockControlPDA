@inherits LayoutComponentBase
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Stock Control — Admin</PageTitle>

<div class="shell">
    <header>
        <div>
            <h1>Stock Control — Admin</h1>
            <p class="sub">
                Compact master-data registration. On PDAs, the scanner types into the focused field and may send <span class="mono">Enter</span>.
            </p>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="header-user">
                    <span class="hint">@context.User.Identity?.Name</span>
                    <button class="btn ghost" type="button" @onclick="SignOutAsync">Sign out</button>
                </div>
            </Authorized>
        </AuthorizeView>
    </header>

    <AdminTabs />

    @Body
</div>

@code {
    private async Task SignOutAsync()
    {
        await Js.InvokeVoidAsync("logoutAdmin");
        Nav.NavigateTo("/", forceLoad: true);
    }
}
